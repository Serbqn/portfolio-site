# =========================================================================
# Serb Portfolio · env example
# Copy to .env.local and fill in the values.
# =========================================================================

# Admin password — min 6 chars. The /admin route will refuse to start until
# this is set. It is never stored; the value is checked in constant time at
# sign-in and then forgotten.
ADMIN_PASSWORD=change-me-please

# JWT signing secret — min 32 chars. Used to sign the session cookie that
# gates /admin. Rotate to invalidate all existing sessions.
ADMIN_TOKEN_SECRET=replace-with-a-random-32-char-secret-string

# Optional · only needed for the contact form to send via a transactional
# email provider. Not configured in the v1 build (the contact form opens the
# user's mail client instead).
# RESEND_API_KEY=
# CONTACT_TO_EMAIL=hello@serb.design
